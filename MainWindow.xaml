<Window x:Class="ZapretUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:ZapretUI.Controls"
        Title="Zapret UI — Niko"
        Height="720" Width="1100"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="Transparent">
        <Grid>
            <controls:HomeBackgroundHost x:Name="AppBackgroundHost"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource TitleBarOverlayBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                            <Image Source="Assets/source.png" Width="20" Height="20" Stretch="Uniform"/>
                            <TextBlock Text="Zapret UI" Margin="8,0,0,0" FontWeight="SemiBold"/>
                            <TextBlock Text="• Автор: Niko" Margin="8,0,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button Content="—" Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click"/>
                            <Button Content="▢" Style="{StaticResource TitleBarButton}" Click="MaximizeButton_Click"/>
                            <Button Content="✕" Style="{StaticResource TitleBarCloseButton}" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource ShellOverlayBrush}" Padding="14">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                                <TextBlock Text="Zapret UI" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Автор: Niko" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="VersionText" Text="v1.2.8" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel x:Name="NavPanel" DockPanel.Dock="Top"/>

                            <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                                <Border Background="#7A181b26" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Статус" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="StatusText" Text="Остановлен" Margin="8,0,0,0" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Column="1" Margin="24">
                        <ContentControl x:Name="PageHost" Background="Transparent"/>

                        <StackPanel x:Name="BgControlsPanel"
                                    Panel.ZIndex="20"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,20,16"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="BgSpeedLabel"
                                       Text="Скорость фона"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Button x:Name="BgSlowBtn" Content="🐢" Width="32" Height="28" Padding="0"
                                        Style="{StaticResource SecondaryButton}" FontSize="14"
                                        ToolTip="Очень медленно (5%)" Click="BgSlowBtn_Click"/>
                                <Slider x:Name="BgSpeedSlider"
                                        Width="110"
                                        Margin="6,0"
                                        Minimum="5"
                                        Maximum="100"
                                        Value="15"
                                        IsMoveToPointEnabled="True"
                                        Opacity="0.9"
                                        ToolTip="5% — очень медленно, 15% — по умолчанию, 100% — быстро"
                                        ValueChanged="BgSpeedSlider_ValueChanged"/>
                                <Button x:Name="BgFastBtn" Content="🚀" Width="32" Height="28" Padding="0"
                                        Style="{StaticResource SecondaryButton}" FontSize="14"
                                        ToolTip="Очень быстро (100%)" Click="BgFastBtn_Click"/>
                            </StackPanel>
                            <Button x:Name="BgSwitchBtn"
                                    Style="{StaticResource SecondaryButton}"
                                    FontSize="11"
                                    Padding="10,4"
                                    Opacity="0.38"
                                    Margin="0,8,0,0"
                                    ToolTip="Сменить фоновую анимацию"
                                    Click="BgSwitchBtn_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
