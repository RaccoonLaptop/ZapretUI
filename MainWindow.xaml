<Window x:Class="ZapretUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:ZapretUI.Controls"
        Title="Zapret UI — Niko"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="720" Width="1100"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="Transparent">
        <Grid>
            <controls:HomeBackgroundHost x:Name="AppBackgroundHost"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource TitleBarOverlayBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                            <Image Source="Assets/source.png" Width="20" Height="20" Stretch="Uniform"/>
                            <TextBlock Text="Zapret UI" Margin="8,0,0,0" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TitleBarAuthor" Text="• Автор: Niko" Margin="8,0,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button Content="—" Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click"/>
                            <Button Content="▢" Style="{StaticResource TitleBarButton}" Click="MaximizeButton_Click"/>
                            <Button Content="✕" Style="{StaticResource TitleBarCloseButton}" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource ShellOverlayBrush}" Padding="14">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                                <TextBlock Text="Zapret UI" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock x:Name="VersionText" Text="v1.2.8" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                                <Border Background="#7A181b26" CornerRadius="8" Padding="10" x:Name="StatusBorder">
                                    <StackPanel>
                                        <TextBlock x:Name="StatusHeader" Text="Статус" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock x:Name="StatusText" Text="Остановлен" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock x:Name="StatusPresetText"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"
                                                           Visibility="Collapsed"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="NavPanel" DockPanel.Dock="Top"/>

                            <StackPanel DockPanel.Dock="Bottom"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Margin="0,12,0,0">
                                <Button x:Name="BgSwitchBtn"
                                        Style="{StaticResource SecondaryButton}"
                                        FontSize="11"
                                        Padding="10,4"
                                        HorizontalAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        Opacity="0.38"
                                        ToolTip="Сменить фоновую анимацию"
                                        Click="BgSwitchBtn_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Column="1" Margin="24">
                        <ContentControl x:Name="PageHost" Background="Transparent"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
