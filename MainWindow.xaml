<Window x:Class="ZapretUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zapret UI — Niko"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" Padding="16">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
                    <TextBlock Text="Zapret UI" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Автор: Niko" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                    <TextBlock x:Name="UiVersionText" Text="Zapret UI v1.0.0" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    <TextBlock x:Name="VersionText" Text="Flowseal v1.9.8c" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel x:Name="NavPanel" DockPanel.Dock="Top"/>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Статус" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" Text="Остановлен" Margin="8,0,0,0" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="RootPathText" TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Border Grid.Column="1" Background="{StaticResource BgBrush}" Padding="24">
            <ContentControl x:Name="PageHost"/>
        </Border>
    </Grid>
</Window>
