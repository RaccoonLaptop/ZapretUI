<Window x:Class="ZapretUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zapret UI"
        Height="720" Width="1100"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" Padding="14">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                    <TextBlock Text="Zapret UI" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock x:Name="VersionText" Text="v1.1.2" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel x:Name="NavPanel" DockPanel.Dock="Top"/>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                    <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Статус" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" Text="Остановлен" Margin="8,0,0,0" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource BgBrush}" Padding="24">
            <ContentControl x:Name="PageHost"/>
        </Border>
    </Grid>
</Window>
