<Window x:Class="ZapretUI.TrayMenuPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="True">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="6"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.45" Color="#000000"/>
        </Border.Effect>
        <StackPanel MinWidth="240">
            <StackPanel Orientation="Horizontal" Margin="16,10,16,4">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="StatusText"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="StrategyText"
                       Margin="34,0,16,6"
                       FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextTrimming="CharacterEllipsis"
                       Visibility="Collapsed"/>

            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="12,4"/>

            <Button x:Name="ToggleBtn"
                    Style="{StaticResource NavButton}"
                    HorizontalContentAlignment="Left"
                    Margin="0,2"
                    Click="ToggleBtn_Click"/>

            <Button x:Name="OpenBtn"
                    Style="{StaticResource NavButton}"
                    HorizontalContentAlignment="Left"
                    Margin="0,2"
                    Click="OpenBtn_Click"/>

            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="12,4"/>

            <Button x:Name="ExitBtn"
                    Style="{StaticResource NavButton}"
                    HorizontalContentAlignment="Left"
                    Margin="0,2"
                    Click="ExitBtn_Click"/>
        </StackPanel>
    </Border>
</Window>
